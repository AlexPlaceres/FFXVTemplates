    local int64 returnPoint<hidden=true>;
    if( tableBase.vTable.tableFieldOffsets[0] )
    {
        FSeek( startof(tableBase.vTableOffset) + tableBase.vTable.tableFieldOffsets[0]);
        int valueVectorOffset<bgcolor=cBlue>;
        int valVectorSize<bgcolor=cGreen>;
        int values[valVectorSize]<bgcolor=cYellow, format=hex>;
    }
} TableC_1C;

typedef struct TableVectorC_1C{
    
    int offset<bgcolor=cBlue>;
    FSeek(startof(offset) + offset);
     

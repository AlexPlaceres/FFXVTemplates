            offset32 offsets[count];
            for(i = 0; i < count; i++) {
                FSeek(startof(offsets[i]) + offsets[i]);
                VfxGraphFCurve_Table fcurve<read=this.anchorPoints.count>;
            }
        } fCurves<read=this.count>;
    }

};

struct VfxGraphBinary_Table {
    vtoffset vTableOffset;
    local int64 p<hidden=true> = startof(vTableOffset) - vTableOffset;

    FSeek(p);
    struct {
        int16 vTableLength<bgcolor=cWhite>;
        int16 tableLength<bgcolor=cWhite>;
        int16 offsets[2]<bgcolor=cGray>;
    } vTable;

    JumpToField(vTableOffset, 0);
    offset32 graphBinaryOffset;

    JumpToField(vTableOffset, 1);
    offset32 vfxTypeDataOffset;

    FSeek(startof(graphBinaryOffset) + graphBinaryOffset);
    GraphBinary_Table graphBinary;

    FSeek(startof(vfxTypeDataOffset) + vfxTypeDataOffset);
    VfxTypeData_Table vfxTypeData;
};

struct VfxHeader {
    char identifier[16];
    Assert(identifier == "FLAT.VFX.GRAPH.B");

    offset32 rootTableOffset;
};

VfxHeader header;
FSeek(startof(header.rootTableOffset) + header.rootTableOffset);
VfxGraphBinary_Table vfxGraphBinary;

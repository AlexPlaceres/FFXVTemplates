        TableC_1C tableC_1C<name = Str("Vector (%d Items) ", this.valVectorSize)>;
       
    }
    
    FSeek(startof(offset) + 4);
    
} TableVectorC_1C;

typedef struct Table1C{
    
    int offset<bgcolor=cBlue>;
    
    FSeek(startof(offset) + offset);
    
    TableBase tableBase;
    local int i <hidden=true>;
    local int returnPoint<hidden=true>;
    
    for ( i = 0 ; i < tableBase.vTable.vTableFieldCount; i++ )
    {
        if(tableBase.vTable.tableFieldOffsets[i])
        {
            returnPoint = SeekTo( FTell() + (tableBase.vTable.tableFieldOffsets[i] - 4 ));
            
            
            
            switch(i)
            {
                case 0:
                {
                    BoolVector boolVector<name = Str("(Field %Xh) Boolean Values (%d)", 0 + 1, this.numValues)>;
                    break;
                }
                case 3:
                {
                    IntVector int32Vector<name = Str("(Field %Xh) Int32 Values (%d)", 3 + 1, this.intNum)>;
                    break;
                }
                case 9:
                {
                    FloatVector float32Vector<name = Str("(Field %Xh) Float32 Values (%d)", 9 + 1, this.numValues)>;
                    break;
                }
                case 11:
                {
                    DependencyPathVector dependencyPathVector<name = Str("(Field %Xh) Char Array Values (%d)", 11 + 1, this.pathNum)>;
                    break;
                }
                case 12:
                {
                    IntVector enumValueVector<name = Str("(Field %Xh) Enum Values (%d)", 12 + 1, this.intNum)>;
                    break;
                }
                case 13:
                {
                    Float4Array float4Array2<name = Str("(Field %Xh) Float2s (%d)", 13 + 1, this.numFloat4)>;
                    break;
                }
                case 14:
                {
                    Float4Array LmVector3Vector<name = Str("(Field %Xh) Float3s (%d)", 14 + 1, this.numFloat4)>;
                    break;
                }
                case 15:
                {
                    Float4Array float4Vector<name = Str("(Field %Xh) Float4s (%d)", 15 + 1, this.numFloat4)>;
                    break;
                }
                case 19:
                {
                    MatrixVector LmMatrix44Vector<name = Str("(Field %Xh) 4x4 Matrices (%d)", 19 + 1, this.numMatrix)>;
                    break;
                }
                case 25:
                {
                    TableVectorC_1C int32VectorTables<name = Str("(Field %Xh) Int32 Vector Tables (%d)", 25 + 1, this.offsetNum)>;
                    break;
                }
                case 35:
                {
                    TableVectorA_1C tableVectorA_1C<name = Str("(Field %Xh) Maybe Vector3 Arrays (%d)", 35, this.offsetNum)>;
                    break;
                }
                case 31:
                {
                    TableVectorB_1C tableVectorB_1C<name = Str("(Field %Xh) Float Arrays (%d)", 31, this.offsetNum)>;
                    break;
                }
                default:
                int value<bgcolor=cWhite>;
            }
            FSeek(returnPoint);
        }
    }
    
    // [19] = Offset to Matrix Array?
    // [25] = Offset to Array of Offsets
    
    FSeek(startof(offset) + 4);
} Table1C;

typedef struct Table1{
    int offset<bgcolor=0xFFBF00>;
    local int64 retPoint<hidden=true>;
    retPoint = SeekTo( FTell() + (offset - 4 ) );
    
    TableBase tableBase;
    
    if(tableBase.vTable.tableFieldOffsets[0])
    {
        Table1A table1A<name="Graph Version Info">;
    }
    if(tableBase.vTable.tableFieldOffsets[1])
    {
        Table1B table1B<name = "Graph Container">;
    }
    if(tableBase.vTable.tableFieldOffsets[2])
    {
        Table1C table1C<name = "Graph Data Structure Node Data">;     
    }
    
    FSeek(retPoint);
    
} Table1;

typedef struct Table2A{
    TableBase tableBase;
    
    local int i <hidden=true>;
    local int64 returnPoint <hidden=true>;
    for( i = 0 ; i < tableBase.vTable.vTableFieldCount ; i++ )
    {
        if(tableBase.vTable.tableFieldOffsets[i])
        {
            returnPoint = SeekTo( FTell() + (tableBase.vTable.tableFieldOffsets[i] - 4 ));
            
            switch(i)
            {
                case 3:
                {
                    CurveKeyVector curveKeys<name = Str("Keys (%d) (Time, XYZ)", this.numKeys)>;
                    break;
                }
                case 2:
                {
                    LmUECurveLoopType type<bgcolor=cRed>;

                    break;
                }
                default:
                int value <bgcolor=cWhite>;
            }
            
            FSeek(returnPoint);
        }
    }
} Table2A;

typedef struct Table2_TableVectorA{
    int tableVectorOffset<bgcolor=0xEDB200>;
    FSeek( startof(tableVectorOffset) + tableVectorOffset );
    int tableOffsetCount <bgcolor=0xDBA400, name = "Number of Tables">;
    int tableOffsets[tableOffsetCount]<bgcolor=0xC89600, name = "Table Offsets">;
    local int i <hidden=true>;
    
    for( i = 0 ; i < tableOffsetCount ; i++ )
    {
        FSeek( startof(tableOffsets[i]) + tableOffsets[i] );
        
        Table2A table2A<name = Str("FCurve (%d Keys) ", this.curveKeys.numKeys)>;
    }
} Table2_TableVectorA;

typedef struct Table2{
    int offset<bgcolor=0xFFBF00>;
    local int64 retPoint<hidden=true>;
    retPoint = SeekTo( FTell() + (offset - 4 ) );
    
    TableBase tableBase;
    
    local int i <hidden=true>;
    local int64 returnPoint <hidden=true>;
    for( i = 0 ; i < tableBase.vTable.vTableFieldCount ; i++ )
    {
        if(tableBase.vTable.tableFieldOffsets[i])
        {
            returnPoint = SeekTo( FTell() + (tableBase.vTable.tableFieldOffsets[i] - 4 ));
            
            switch(i)
            {
                case 6:
                {
                    Table2_TableVectorA table2_TableVectorA<bgcolor=cBlue, name = Str("VFX Graph FCurve Vector (%d)", this.tableOffsetCount)>;
                    break;
                }
                default:
            }
            
            FSeek(returnPoint);
        }
    }
    
    FSeek(retPoint);
} Table2;

typedef struct RootTable(int offset){
    local int64 returnPoint<hidden=true>;
    returnPoint = SeekTo( offset );
    
    TableBase tableBase;
    
    if( tableBase.vTable.tableFieldOffsets[0] ){
        Table1 table1<name="Graph Binary">;
    }
    if( tableBase.vTable.tableFieldOffsets[1] ){
        Table2 table2<name="VFX Graph Binary">;
    }
        
    FSeek(returnPoint);
    
} RootTable;

typedef struct FlatBufferBinary{
    int rootTableOffset<bgcolor=cBlue>;
    char identifier[4]<bgcolor=cYellow>;
    RootTable rootTable( startof(rootTableOffset) + rootTableOffset )<name="VFX FlatBuffer Binary">;
    
    
} FlatBufferBinary;

typedef struct Header{
    char magic[16]<bgcolor=cYellow>;
    int rootTableOffset<bgcolor=cBlue>;
    while(!ReadInt())
    {
        int padding<hidden=true>;
    }
    
} Header;

struct LmVFXBin{
    Header header;
    
    FlatBufferBinary flatBufferBinary;
};

LmVFXBin bin<name = "Luminous VFX Graph FlatBuffer Binary">;
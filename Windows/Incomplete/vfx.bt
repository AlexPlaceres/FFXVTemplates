typedef struct type_Vector2_Struct {
    float x;
    float y;
    uint64 padding;
} Vector2_Struct<read=Str("%.3f, %.3f", this.x, this.y)>;

typedef struct type_Vector3_Struct {
    float x;
    float y;
    float z;
    int padding;
} Vector3_Struct<read=Str("%.3f, %.3f, %.3f", this.x, this.y, this.z)>;

typedef struct type_Vector4_Struct {
    float x;
    float y;
    float z;
    float w;
} Vector4_Struct<read=Str("%.3f, %.3f, %.3f, %.3f", this.x, this.y, this.z, this.w)>;

struct Matrix44_Struct {
    Vector4_Struct row0;
    Vector4_Struct row1;
    Vector4_Struct row2;
    Vector4_Struct row3;
};

typedef struct type_FlatBufferString {

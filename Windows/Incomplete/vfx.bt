ubyte JumpToField(offset32& o, int32 i) {
    local int16 fieldOffset = ReadShort((startof(o) - o) + 4 + 2 * i);
    if(fieldOffset) {
        FSeek(startof(o) + fieldOffset);
        return 1;
    }
    return 0;
}

typedef struct type_FloatArray_Table {
    vtoffset vTableOffset;
    local int64 p<hidden=true> = startof(vTableOffset) - vTableOffset;

    FSeek(p);
    struct {
        int16 vTableLength<bgcolor=cWhite>;
        int16 tableLength<bgcolor=cWhite>;
        int16 offsets[1]<bgcolor=cGray>;
    } vTable;

    JumpToField(vTableOffset, 0);
    offset32 o_data;
    FSeek(startof(o_data) + o_data);
    int count<fgcolor=COLOR_COUNT>;
    float data[count];
} FloatArray_Table<read=this.count>;

typedef struct type_Int32Array_Table {

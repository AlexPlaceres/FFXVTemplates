enum LinkType
{
  LinkTypeUnknown = 0x0,
  LinkTypeSignal = 0x1,
  LinkTypeCreateSignal = 0x2,
  LinkTypeOnce = 0x3,
  LinkTypeEveryFrame = 0x4,
};


enum PropertyValueType{
    kBool = 0x1,
    kInt32 = 0x2,
    kFloat32 = 0x3,
    kLmUVector2 = 0x4,
    kLmUVector3 = 0x5,
    kLmUVector4 = 0x6,
    kLmUMatrix44 = 0x7,
    kString = 0x8,
    kPointer = 0x9,
    kInt32Vector = 0xA,
    kFCurveMaybe = 0xB,
    kFloatArray = 0xC,
    kLmVector4Array = 0xF,
    kVectorData = 0x10,
    kLmUEAlphaBlendType = 0x12,
    kLmUERenderFaceType = 0x20,
    kLmUESignedAreaType = 0x24,
    kMaxTypes = 0x99,
};

enum PropertyBaseType
{

  kBaseType_None = 0x0,
  kBaseType_Byte = 0x1,
  kBaseType_Bool = 0x2,
  kBaseType_Int16 = 0x3,
  kBaseType_Int32 = 0x4,
  kBaseType_Int64 = 0x5,
  kBaseType_Ubyte = 0x6,
  kBaseType_Uint16 = 0x7,
  kBaseType_Uint32 = 0x8,
  kBaseType_Uint64 = 0x9,
  kBaseType_Float = 0xA,
  kBaseType_Double = 0xB,
  kBaseType_String = 0xC,
  kBaseType_Vector2 = 0xD,
  kBaseType_Vector3 = 0xE,
  kBaseType_Vector4 = 0xF,
  kBaseType_Color = 0x10,
  kBaseType_Matrix33 = 0x11,
  kBaseType_Matrix34 = 0x12,
  kBaseType_Matrix44 = 0x13,
  kBaseType_Quaternion = 0x14,
  kBaseType_Euler = 0x15,
  kBaseType_Enum = 0x16,
  kBaseType_ByteArray = 0x17,
  kBaseType_UbyteArray = 0x18,
  kBaseType_Int16Array = 0x19,
  kBaseType_Int32Array = 0x1A,
  kBaseType_Int64Array = 0x1B,
  kBaseType_Uint32Array = 0x1C,
  kBaseType_Uint16Array = 0x1D,
  kBaseType_Uint64Array = 0x1E,
  kBaseType_FloatArray = 0x1F,
  kBaseType_DoubleArray = 0x20,
  kBaseType_StringArray = 0x21,
  kBaseType_Vector2Array = 0x22,
  kBaseType_Vector3Array = 0x23,
  kBaseType_Vector4Array = 0x24,
  kBaseType_ColorArray = 0x25,
  kBaseType_Matrix33Array = 0x26,
  kBaseType_Matrix34Array = 0x27,
  kBaseType_Matrix44Array = 0x28,
  kBaseType_QuaternionArray = 0x29,
  kBaseType_EulerArray = 0x2A,
  kBaseType_EnumArray = 0x2B,
  kBaseType_Count = 0x2C,
  kBaseType_VFXType = 0x400,
  kVFXType_Box = 0x400,
  kVFXType_kSphere = 0x401,
  kVFXType_kPointer = 0x402,
  kVFXType_kVectorData = 0x403,
  kVFXType_kOffset = 0x404,
  kVFXType_kOffsetArray = 0x405,
  kVFXType_kFCurve = 0x406,
};


int64 SeekTo( int64 offset ){
    local int64 returnPoint = FTell();
    
    FSeek(offset);
    
    return returnPoint;
}

typedef struct DependencyPath{
    int pathOffset<bgcolor=cBlue>;
    returnPoint = SeekTo( FTell() + (pathOffset - 4) );
    
    unsigned int pathLength<bgcolor=cRed>;
    char path[pathLength]<bgcolor=cYellow>;
    
    FSeek(returnPoint);
}   DependencyPath;

typedef struct DependencyPathVector{
    int offset<bgcolor=cBlue>;
    FSeek(startof(offset) + offset);
    
    unsigned int pathNum;
    local int i <hidden=true>;
    local int64 returnPoint<hidden=true>;
    
    for( i = 0 ; i < pathNum; i++ )
    { 
        DependencyPath path<name = Str("%s", exists(this.path) ? this.path : "null")>;
    }
    
    FSeek(startof(offset) + 4);
    
} DependencyPathVector;

typedef struct Float4{
    float x, y, z, w;
} Float4;

typedef struct Float4Array{
    int offset<bgcolor=cBlue>;
    FSeek(startof(offset) + offset);
    
    unsigned int numFloat4;
    Float4 float4s[numFloat4]<bgcolor=cYellow, name = Str("X: %.3f, Y: %.3f, Z: %.3f, W: %.3f", this.x, this.y, this.z, this.w)>;
    
    FSeek(startof(offset) + 4);
} Float4Array;

typedef struct CurveKeyVector{
    int offset<bgcolor=cBlue>;
    FSeek(startof(offset) + offset);
    
    unsigned int numKeys;
    Float4 Key[numKeys]<bgcolor=cYellow, name = Str("Time: %.3fs, X: %.3f, Y: %.3f, Z: %.3f", this.x, this.y, this.z, this.w)>;
    
    FSeek(startof(offset) + 4);
} CurveKeyVector;

typedef struct Matrix{
    Float4 rows [4]<name = Str("X: %.3f, Y: %.3f, Z: %.3f, W: %.3f", this.x, this.y, this.z, this.w)>;
} Matrix;

typedef struct Color{
    float r, g, b, a;
} Color;

typedef struct ColorVector{
    int offset<bgcolor=cBlue>;
    FSeek(startof(offset) + offset);
    
    unsigned int numColors;
    Color colors[numColors]<bgcolor=cYellow>;
    
    FSeek(startof(offset) + 4);
} ColorVector;

typedef struct MatrixVector{
    int offset<bgcolor=cBlue>;
    
    FSeek(startof(offset) + offset);
    
    unsigned int numMatrix<bgcolor=cGreen>;
    Matrix matrices[numMatrix]<bgcolor=cYellow>;
    
    FSeek(startof(offset) + 4);
}   MatrixVector;

typedef struct IntVector{
    int offset<bgcolor=cBlue>;
    
    FSeek(startof(offset) + offset);
    int intNum<bgcolor=cGreen>;
    int values[intNum]<bgcolor=cWhite, format=hex>;
    
    FSeek(startof(offset) + 4);
    
}   IntVector;

typedef struct FloatVector{  
    int offset<bgcolor=cBlue>;
    FSeek(startof(offset) + offset);
    
    unsigned int numValues<bgcolor=cGreen>;
    float values[numValues]<bgcolor=cYellow>;
    
    FSeek(startof(offset) + 4);
}   FloatVector;

typedef struct BoolVector{  
    int offset<bgcolor=cBlue>;
    FSeek(startof(offset) + offset);
    
    unsigned int numValues<bgcolor=cGreen>;
    ubyte values[numValues]<bgcolor=cYellow, name = (this == 1 ? "True " : "False ")>;
    
    FSeek(startof(offset) + 4);
}   BoolVector;

typedef struct VirtualTable( int offset ){
    local int64 returnPoint<hidden=true>;
     returnPoint = SeekTo( FTell() - offset);
    
    short vTableLength<bgcolor=cPurple>;
    short tableLength<bgcolor=cRed>;
    
    local uint vTableFieldCount = (vTableLength - 4 ) / 2;
    local uint TableFieldCount = 0;
    local int i<hidden=true>;
    short tableFieldOffsets[vTableFieldCount]<bgcolor=cGray>;
    for( i = 0 ; i < vTableFieldCount; i++ )
    {
        TableFieldCount += tableFieldOffsets[i] ? 1 : 0;
    }
    
    FSeek( returnPoint );  
    
} VirtualTable;

typedef struct TableBase{
    int vTableOffset<bgcolor=cPurple>;
    VirtualTable vTable( vTableOffset + 4 );
} TableBase;

typedef struct GraphVersionInfo{
    uint Self_;
    uint Tool_;
    uint Converter_;
    
} GraphVersionInfo;

typedef struct GraphNodeMember{
    int memberId_<format=hex>;
    PortNameHash name_<format=hex>;
} GraphNodeMember;

typedef struct Table1A{
    int offset<bgcolor=cBlue>;
    
    FSeek(startof(offset) + offset);
    
    TableBase tableBase;
    if(tableBase.vTable.tableFieldOffsets[0])
    {
        GraphVersionInfo graphVersionInfo<bgcolor=cWhite, name = Str("Self v%d, Tool v%d, Converter v%d", this.Self_, this.Tool_, this.Converter_)>;
    }
    
    FSeek(startof(offset) + 4);
} Table1A;

typedef struct TableA1_1B{
    TableBase tableBase;
    
    local int i <hidden=true>;
    local int returnPoint<hidden=true>;
    for ( i = 0 ; i < tableBase.vTable.vTableFieldCount; i++ )
    {
        if(tableBase.vTable.tableFieldOffsets[i])
        {
            returnPoint = SeekTo( FTell() + (tableBase.vTable.tableFieldOffsets[i] - 4 ));
            

            
            switch(i)
            {
                case 0:
                {
                    GraphNodeMember graphNodeMember<name="Member Information">;
                    break;
                }
                case 1:
                {
                    PropertyValueType propertyValueType<bgcolor=0xD2D99D>;
                    break;
                }
                case 2:
                {
                    PropertyBaseType baseType<bgcolor=0x3689D5, format=hex>;
                    int valueIndex<bgcolor=0x0042A4>;
                    break;
                }
                default:
            }
            
            FSeek(returnPoint);
        }
    }
} TableA1_1B;

typedef struct TableA1_1B_Array
{
    int offsetNum<bgcolor=cGreen, name = "Maybe Dynamic Property Count">;
    int offsets[offsetNum]<bgcolor=cBlue>;
    
    local int i <hidden=true>;
    for( i = 0 ; i < offsetNum ; i++ )
    {
        FSeek( startof(offsets[i]) + offsets[i] );
        TableA1_1B tableA1_1B <name = Str("%X (%s @ Index: %d) ",this.graphNodeMember.memberId_ ,EnumToString(this.propertyValueType), this.valueIndex)>;
    }
} TableA1_1B_Array;

typedef struct TableA2_1B{
    TableBase tableBase;
    
    local int i <hidden=true>;
    local int returnPoint<hidden=true>;
    for ( i = 0 ; i < tableBase.vTable.vTableFieldCount; i++ )
    {
        if(tableBase.vTable.tableFieldOffsets[i])
        {
            returnPoint = SeekTo( FTell() + (tableBase.vTable.tableFieldOffsets[i] - 4 ));
            
            switch(i)
            {
                case 0:
                {
                    int portId<bgcolor=cYellow, format=hex>;
                    PortNameHash nameHash<bgcolor=cYellow, format=hex>;
                    break;
                }
                case 1:
                {
                    int otherVal<bgcolor=cGray>;
                    break;
                }
                default:
            }
            
            FSeek(returnPoint);
        }
    }
} TableA2_1B;

            

typedef struct TableA2_1B_Array
{
    int offsetNum<bgcolor=cGreen>;
    int offsets[offsetNum]<bgcolor=cBlue>;
    
    local int i <hidden=true>;
    for( i = 0 ; i < offsetNum ; i++ )
    {
        FSeek( startof(offsets[i]) + offsets[i] );
        TableA2_1B tableA2_1B<name = Str("Input Signal %X (Hash: %X) ", this.portId, this.nameHash)>;
    }
} TableA2_1B_Array;

typedef struct TableA3_1B{
    TableBase tableBase;
    
    local int i <hidden=true>;
    local int returnPoint<hidden=true>;
    for ( i = 0 ; i < tableBase.vTable.vTableFieldCount; i++ )
    {
        if(tableBase.vTable.tableFieldOffsets[i])
        {
            returnPoint = SeekTo( FTell() + (tableBase.vTable.tableFieldOffsets[i] - 4 ));
            
            switch(i)
            {
                case 0:
                {
                    GraphNodeMember memberInfo;
                    break;
                }
                case 1:
                {
                    int otherVal<bgcolor=cGray>;
                    break;
                }
                default:
            }
            
            FSeek(returnPoint);
        }
    }
} TableA3_1B;

typedef struct TableA3_1B_Array
{
    int offsetNum<bgcolor=cGreen>;
    int offsets[offsetNum]<bgcolor=cBlue>;
    
    local int i <hidden=true>;
    for( i = 0 ; i < offsetNum ; i++ )
    {
        FSeek( startof(offsets[i]) + offsets[i] );
        TableA3_1B tableA3_1B;
    }
} TableA3_1B_Array;



typedef struct TableA_1B
{
    int offset<bgcolor=cBlue>;
    FSeek(startof(offset) + offset);
    
    TableBase tableBase;
    
    local int i <hidden=true>;
    local int returnPoint<hidden=true>;
    for ( i = 0 ; i < tableBase.vTable.vTableFieldCount; i++ )
    {
        if(tableBase.vTable.tableFieldOffsets[i])
        {
            returnPoint = SeekTo( FTell() + (tableBase.vTable.tableFieldOffsets[i] - 4 ));
            
            switch(i)
            {
                case 0:
                {
                    int nodeId<bgcolor=cLtGreen, format=hex>;
                    NodeType nodeTypeId<bgcolor=0x6F03A4, format=hex>;
                    break;
                }
                case 1:
                {
                    int arrayOffset<bgcolor=cBlue>;
                    FSeek( startof(arrayOffset) + arrayOffset );
                    TableA1_1B_Array table_A1_1B_Array<name = Str("Modified Properties (%d)", this.offsetNum)>;
                    break;
                }
                case 2:
                {
                    int arrayOffset2<bgcolor=cBlue>;
                    FSeek( startof(arrayOffset2) + arrayOffset2 );
                    TableA2_1B_Array tableA2_1B_Array<name = Str("Input Ports (%d)", this.offsetNum)>;
                    break;
                }
                case 3:
                {
                    int arrayOffsetMaybe<bgcolor=cBlue>;
                    FSeek( startof(arrayOffsetMaybe) + arrayOffsetMaybe );
                    TableA3_1B_Array tableA3_1B_Array<name = Str("Output Ports (%d)", this.offsetNum)>;
                    break;
                }
                default:
            };
            
            FSeek(returnPoint);
        }
    }
    
    FSeek(startof(offset) + 4);
} TableA_1B;

typedef struct TableB_1B
{
    int offset<bgcolor=cBlue>;
    FSeek(startof(offset) + offset);
    
    TableBase tableBase;
    
    local int i <hidden=true>;
    local int returnPoint<hidden=true>;
    for ( i = 0 ; i < tableBase.vTable.vTableFieldCount; i++ )
    {
        if(tableBase.vTable.tableFieldOffsets[i])
        {
            returnPoint = SeekTo( FTell() + (tableBase.vTable.tableFieldOffsets[i] - 4 ));
            
            
            switch(i)
            {
                case 0:
                {
                    int parentNodeID<bgcolor=cRed, format=hex>;
                    break;
                }
                case 1:
                {
                    int parentNodeType<bgcolor=cRed, format=hex>;
                    break;
                }
                case 2:
                {
                    IntVector childNodes;
                    break;
                }
                default:
            }
            
            FSeek(returnPoint);
        }
    }
    FSeek(startof(offset) + 4);
} TableB_1B;

typedef struct TableC_1B
{
    int offset<bgcolor=cBlue>;
    FSeek(startof(offset) + offset);
    
    TableBase tableBase;
    
    local int i <hidden=true>;
    local int returnPoint<hidden=true>;
    for ( i = 0 ; i < tableBase.vTable.vTableFieldCount; i++ )
    {
        if(tableBase.vTable.tableFieldOffsets[i])
        {
            returnPoint = SeekTo( FTell() + (tableBase.vTable.tableFieldOffsets[i] - 4 ));
            
            switch(i)
            {
                case 0:
                {
                    int field0;
                    break;
                }
                case 1:
                {
                    int sourceNodeID<format=hex>;
                    break;
                }
                case 2:
                {
                    int sourceNodePortID<format=hex>;
                    break;
                }
                case 3:
                {
                    int destinationNodeID<format=hex>;
                    break;
                }
                case 4:
                {
                    int destinationPortID<format=hex>;
                    break;
                }
                case 5:
                {
                    int field5;
                    break;
                }
                case 6:
                {
                    int field6;
                    break;
                }
                default:
                
            }
           
            
            FSeek(returnPoint);
        }
    }
    FSeek(startof(offset) + 4);
} TableC_1B;

typedef struct TableD_1B
{
    int offset<bgcolor=cBlue>;
    FSeek(startof(offset) + offset);
    
    TableBase tableBase;
    
    local int i <hidden=true>;
    local int returnPoint<hidden=true>;
    for ( i = 0 ; i < tableBase.vTable.vTableFieldCount; i++ )
    {
        if(tableBase.vTable.tableFieldOffsets[i])
        {
            returnPoint = SeekTo( FTell() + (tableBase.vTable.tableFieldOffsets[i] - 4 ));
            
            
            
            switch(i)
            {
                case 0:
                {
                    int value_0<bgcolor=cDkRed>;
                    break;
                }
                case 1:
                {
                    int sourceNodeID<bgcolor=cDkRed, format=hex>;
                    break;
                }
                case 2:
                {
                    int sourcePortID<bgcolor=cDkRed, format = hex>;
                    
                    break;
                }
                case 3:
                {
                    int destinationNodeID<bgcolor=cDkRed, format=hex>;
                    break;
                }
                case 4:
                {
                    int destinationPortID<bgcolor=cDkRed, format = hex>;
                    break;
                }
                case 5:
                {
                    LinkType maybeLinkType<bgcolor=cDkRed>;
                    break;
                }
                case 6:
                {
                    int value_6<bgcolor=cDkRed>;
                    break;
                }
                default:
            }
            
            FSeek(returnPoint);
        }
    }
    FSeek(startof(offset) + 4);
} TableD_1B;

typedef struct TableArrayA_1B{
    int offset<bgcolor=cBlue>;
    
    FSeek(startof(offset) + offset);
    
    int offsetNum<bgcolor=cGreen>;
    
    local int i <hidden=true>;
    for( i = 0 ; i < offsetNum ; i++ )
    {
        TableA_1B tableA_1B<name = Str("%s_0x%X ",EnumToString(this.nodeTypeId), this.nodeId)>;
    }
    
    FSeek(startof(offset) + 4);  
} TableArrayA_1B;

typedef struct TableArrayB_1B{
    int offset<bgcolor=cBlue>;
    
    FSeek(startof(offset) + offset);
    
    int offsetNum<bgcolor=cGreen>;
    
    local int i <hidden=true>;
    for( i = 0 ; i < offsetNum ; i++ )
    {
        TableB_1B tableB_1B<name = Str("Node %X (%d Children) ", this.parentNodeID, this.childNodes.intNum)>;
    }
    
} TableArrayB_1B;

typedef struct TableArrayC_1B{
    int offset<bgcolor=cBlue>;
    
    FSeek(startof(offset) + offset);
    
    int offsetNum<bgcolor=cGreen>;
    
    local int i <hidden=true>;
    for( i = 0 ; i < offsetNum ; i++ )
    {
        TableC_1B tableC_1B<name = Str("Node %X: Port %X => Node %X: Port %X ", this.sourceNodeID, this.sourceNodePortID, this.destinationNodeID, this.destinationPortID)>;
    }
    
} TableArrayC_1B;

typedef struct TableArrayD_1B{
    
    int offset<bgcolor=cBlue>;
    
    FSeek(startof(offset) + offset);
    
    int offsetNum<bgcolor=cGreen>;
    
    local int i <hidden=true>;
    for( i = 0 ; i < offsetNum ; i++ )
    {
        TableD_1B tableD_1B<name = Str("Node %X: Port %X => Node %X: Port %X ", this.sourceNodeID, this.sourcePortID, this.destinationNodeID, this.destinationPortID)>;
    }
    
} TableArrayD_1B;

typedef struct Table1B{
    int offset<bgcolor=cBlue>;
    
    FSeek(startof(offset) + offset);
    
    TableBase tableBase;
    
    local int i <hidden=true>;
    local int returnPoint<hidden=true>;
    for ( i = 0 ; i < tableBase.vTable.vTableFieldCount; i++ )
    {
        if(tableBase.vTable.tableFieldOffsets[i])
        {
            returnPoint = SeekTo( FTell() + (tableBase.vTable.tableFieldOffsets[i] - 4 ));
            
            switch(i)
            {
                case 0:
                {
                    TableArrayA_1B tableVector_1Ba<name = Str("Vector (Node Data) (%d)", this.offsetNum)>;
                    break;
                }
                case 1:
                {
                    TableArrayB_1B tableVector_1Bb<name = Str("Vector (Graph Trays) (%d)", this.offsetNum)>; // Maybe Node Groups
                    break;
                }
                case 2:
                {
                    TableArrayC_1B tableVector_1Bc<name = Str("Vector (Graph Signal Links) (%d)", this.offsetNum)>; // Maybe Link 
                    break;
                }
                case 3:
                {
                    TableArrayD_1B tableVector_1Bd<name = Str("Vector (Graph Property Links) (%d)", this.offsetNum)>;
                    break;
                }
                default:
            }
            
            FSeek(returnPoint);
        }
    }
    
    FSeek(startof(offset) + 4);        
} Table1B;

typedef struct TableA_1C{
    TableBase tableBase;
    
    local int64 returnPoint<hidden=true>;
    if( tableBase.vTable.tableFieldOffsets[0] )
    {
        returnPoint = SeekTo( startof(tableBase.vTableOffset) + tableBase.vTable.tableFieldOffsets[0]);
        int float4VectorOffset <bgcolor=cBlue>;
        FSeek( startof(float4VectorOffset) + float4VectorOffset);
        struct{

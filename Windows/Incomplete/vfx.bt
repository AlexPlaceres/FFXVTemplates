    local int64 returnPoint<hidden=true>;
    if( tableBase.vTable.tableFieldOffsets[0] )
    {
        returnPoint = SeekTo( startof(tableBase.vTableOffset) + tableBase.vTable.tableFieldOffsets[0]);
        int float4VectorOffset <bgcolor=cBlue>;
